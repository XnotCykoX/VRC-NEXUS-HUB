    {
      "id": "script-rotating-status",
      "type": "script",
      "name": "Rotating Status",
      "author": "VRC Nexus",
      "description": "Cycles a few chatbox messages every 15 seconds. A good starting template.",
      "tags": [
        "example",
        "chatbox"
      ],
      "payload": {
        "code": "import random\n\nasync def main():\n    messages = [\n        \"✨ Powered by VRC Nexus\",\n        \"🌐 Community Hub example script\",\n        \"👋 Say hi!\",\n    ]\n    while True:\n        chatbox(random.choice(messages))\n        await wait(15)\n\ncreate_task(main())"
      },
      "publishedAt": "2026-07-05T08:28:03.091Z",
      "likedBy": []
    }
