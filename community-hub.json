    {
      "id": "script-rotating-status",
      "type": "script",
      "name": "Rotating Status",
      "author": "VRC Nexus",
      "description": "Cycles a few chatbox messages every 15 seconds. A good starting template.",
      "tags": [
        "example",
        "chatbox"
      ],
      "payload": {
        "code": "import random\n\nasync def main():\n    messages = [\n        \"✨ Powered by VRC Nexus\",\n        \"🌐 Community Hub example script\",\n        \"👋 Say hi!\",\n    ]\n    while True:\n        chatbox(random.choice(messages))\n        await wait(15)\n\ncreate_task(main())"
      },
      "publishedAt": "2026-07-05T08:28:03.091Z",
      "likedBy": []
    },
    {
      "id": "script-4d3c7dd0-22cd-4372-a79c-56e2caa10f87",
      "type": "script",
      "name": "Universal Rainbow",
      "author": "_cykoo_",
      "description": "Universal Rainbow Script",
      "tags": [
        "Rainbow"
      ],
      "payload": {
        "code": "async def rainbow_cycle():\n    while True:\n        for i in range(0, 200):\n            n = i if i <= 100 else 200 - i\n            set_hue(n / 100)\n            set_emission(n / 100)\n            await wait(0.08)\n\ncreate_task(rainbow_cycle())"
      },
      "publishedAt": "2026-07-05T08:52:23.890Z",
      "installId": "ins_83f6991e-7a16-0984-7cfe-8aa8e0f6375b",
      "likedBy": []
    },
